{
  "name": "sap-project-mgmt",
  "version": "1.0.0",
  "description": "SAP Project Management App — Transport Command Center",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@cap-js/hana": "^1",
    "@sap-cloud-sdk/connectivity": "^3",
    "@sap-cloud-sdk/http-client": "^3",
    "@sap/cds": "^8",
    "@sap/xssec": "^4",
    "express": "^4",
    "express-rate-limit": "^7",
    "node-cron": "^4.2.1",
    "passport": "^0.7",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^1",
    "@sap/cds-dk": "^8",
    "jest": "^29",
    "supertest": "^6"
  },
  "overrides": {
    "better-sqlite3": "^12.9.0"
  },
  "scripts": {
    "start": "cds-serve",
    "setup": "cds deploy --to sqlite:db.sqlite",
    "dev": "cds watch",
    "build": "cds build --production",
    "build:frontend": "cd frontend && npx vite build",
    "deploy:local": "npm run setup && npm run build:frontend && cds-serve",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest test/unit",
    "test:integration": "jest test/integration"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sql"
      },
      "[production]": {
        "db": {
          "kind": "hana-cloud"
        },
        "auth": {
          "kind": "xsuaa"
        }
      },
      "[development]": {
        "db": {
          "kind": "sqlite",
          "credentials": {
            "url": "db.sqlite"
          }
        },
        "auth": {
          "kind": "dummy",
          "_note_mocked_users": "Use 'mocked' instead of 'dummy' when testing role restrictions. Dummy grants all scopes, no auth challenge.",
          "users": {
            "admin@test.com": {
              "password": "pass",
              "roles": [
                "SuperAdmin",
                "Admin",
                "Manager",
                "Executive",
                "Developer",
                "SAP",
                "Coupa",
                "Commercial"
              ]
            },
            "manager@test.com": {
              "password": "pass",
              "roles": [
                "Manager",
                "Developer",
                "SAP"
              ]
            },
            "dev@test.com": {
              "password": "pass",
              "roles": [
                "Developer",
                "SAP"
              ]
            },
            "exec@test.com": {
              "password": "pass",
              "roles": [
                "Executive",
                "SAP",
                "Coupa",
                "Commercial"
              ]
            },
            "coupa-mgr@test.com": {
              "password": "pass",
              "roles": [
                "Manager",
                "Developer",
                "Coupa"
              ]
            },
            "commercial-mgr@test.com": {
              "password": "pass",
              "roles": [
                "Manager",
                "Developer",
                "Commercial"
              ]
            }
          }
        }
      }
    },
    "hana": {
      "deploy-format": "hdbtable"
    }
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/frontend/",
      "/gen/"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/test/"
    ],
    "modulePathIgnorePatterns": [
      "/gen/"
    ]
  }
}
