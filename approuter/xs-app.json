{
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/api/(.*)$",
      "target": "/api/$1",
      "destination": "srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": true
    },
    {
      "source": "^/assets/(.*)$",
      "target": "/assets/$1",
      "localDir": "webapp",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^.*\\.(js|css|ico|png|jpg|svg|webp|woff|woff2|json|map|txt)$",
      "target": "$0",
      "localDir": "webapp",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^(.*)$",
      "target": "/index.html",
      "localDir": "webapp",
      "authenticationType": "xsuaa"
    }
  ]
}
