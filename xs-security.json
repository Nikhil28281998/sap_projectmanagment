{
  "xsappname": "sap-project-mgmt",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.Admin",
      "description": "Full admin access — user management, all configuration, all data"
    },
    {
      "name": "$XSAPPNAME.Manager",
      "description": "Project management — categorization, reports, tools"
    },
    {
      "name": "$XSAPPNAME.Developer",
      "description": "Developer access — own TRs, pipeline, search"
    },
    {
      "name": "$XSAPPNAME.Executive",
      "description": "Executive read-only access — dashboards and reports"
    }
  ],
  "role-templates": [
    {
      "name": "Admin",
      "description": "Full admin access — inherits all other roles",
      "scope-references": [
        "$XSAPPNAME.Admin",
        "$XSAPPNAME.Manager",
        "$XSAPPNAME.Executive",
        "$XSAPPNAME.Developer"
      ]
    },
    {
      "name": "Manager",
      "description": "Project management access",
      "scope-references": [
        "$XSAPPNAME.Manager",
        "$XSAPPNAME.Executive",
        "$XSAPPNAME.Developer"
      ]
    },
    {
      "name": "Developer",
      "description": "Developer self-service access",
      "scope-references": ["$XSAPPNAME.Developer"]
    },
    {
      "name": "Executive",
      "description": "Leadership dashboard access",
      "scope-references": ["$XSAPPNAME.Executive"]
    }
  ],
  "role-collections": [
    {
      "name": "SAP-PM-Admin",
      "description": "Maps to Okta group: IT-SAPAdmins",
      "role-template-references": [
        { "role-template-name": "Admin", "app-id": "$XSAPPNAME" }
      ]
    },
    {
      "name": "SAP-PM-Manager",
      "description": "Maps to Okta group: IT-AppManagers",
      "role-template-references": [
        { "role-template-name": "Manager", "app-id": "$XSAPPNAME" }
      ]
    },
    {
      "name": "SAP-PM-Developer",
      "description": "Maps to Okta group: IT-SAPDevelopers",
      "role-template-references": [
        { "role-template-name": "Developer", "app-id": "$XSAPPNAME" }
      ]
    },
    {
      "name": "SAP-PM-Executive",
      "description": "Maps to Okta group: IT-Leadership",
      "role-template-references": [
        { "role-template-name": "Executive", "app-id": "$XSAPPNAME" }
      ]
    }
  ],
  "oauth2-configuration": {
    "redirect-uris": [
      "https://*.cfapps.*.hana.ondemand.com/**"
    ],
    "token-validity": 43200
  }
}
