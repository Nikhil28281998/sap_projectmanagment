# ─── SAP System Landscape ───
# Map your SAP System IDs to display names (DEV/QAS/PRD)
SAP_SYSTEM_MAP=DS4=DEV,QS4=QAS,PS4=PRD
# System hierarchy: highest environment first (used to derive "current system")
SAP_SYSTEM_HIERARCHY=PS4,QS4,DS4
# Filter transports to these systems only (comma-separated). Empty = all systems.
SAP_SYSTEMS=DS4,QS4,PS4
# Default client for RFC calls
SAP_CLIENT=210

# ─── SAP Cloud Connector / RFC ───
RFC_DEST_NAME=S4HANA_RFC
USE_MOCK_RFC=true          # Set to false when SAP RFC is ready

# ─── SharePoint Graph API ───
SHAREPOINT_TENANT_ID=your-tenant-id
SHAREPOINT_CLIENT_ID=your-client-id
SHAREPOINT_CLIENT_SECRET=your-client-secret
SHAREPOINT_SITE_ID=your-site-id
SHAREPOINT_LIST_ID=your-list-id

# ─── AI Provider (Claude or ChatGPT) ───
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── App Configuration ───
TR_START_DATE=20260101     # YYYYMMDD — fetch transports from this date
REFRESH_INTERVAL_MINUTES=60
ENABLE_AI=false
ENABLE_NOTIFICATIONS=false
