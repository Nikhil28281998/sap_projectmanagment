{
  "build": {
    "target": "gen",
    "tasks": [
      {
        "for": "hana",
        "src": "db",
        "options": {
          "model": ["db", "srv"]
        }
      },
      {
        "for": "node-cf",
        "src": "srv",
        "options": {
          "model": ["db", "srv"]
        }
      }
    ]
  },
  "hana": {
    "deploy-format": "hdbtable"
  },
  "odata": {
    "version": "v4"
  },
  "query": {
    "limit": {
      "default": 100,
      "max": 500
    }
  },
  "log": {
    "levels": {
      "db": "info",
      "cds": "info",
      "serve": "info"
    }
  },
  "features": {
    "fiori_preview": false
  },
  "[development]": {
    "features": {
      "mocked_bindings": true
    }
  }
}
